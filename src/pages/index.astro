---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Timeline from "../components/Timeline.astro";
---

<Layout>
  <!-- Navbar -->
  <Navbar />

  <!-- Main Content -->
  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    
    <!-- Hero Section -->
    <section id="home" class="min-h-[75vh] flex flex-col justify-center py-12 md:py-20 relative">
      <div class="max-w-3xl">
        <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-blue/10 text-brand-blue border border-brand-blue/20 mb-6 tracking-wider uppercase">
          Welcome to my profile
        </span>
        
        <h1 class="text-4xl sm:text-6xl md:text-7xl font-extrabold tracking-tight text-white mb-6">
          Hi, I am <br class="sm:hidden" />
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-purple to-brand-yellow">
            Georg Hackenberg
          </span>
        </h1>
        
        <p class="text-xl sm:text-2xl font-bold text-gray-300 mb-8 leading-normal tracking-wide">
          Professor for Industrial Informatics &bull; Entrepreneur &bull; Software Engineer
        </p>
        
        <p class="text-gray-400 text-base sm:text-lg leading-relaxed mb-10 font-normal">
          I am a computer science professor, software engineer, and entrepreneur from Bavaria, Germany living in Upper Austria. On this page you can find details about my software projects, academic teaching, and core focuses. I am passionate about engineering modern software platforms, building rich knowledge graph architectures, and training the next generation of engineers.
        </p>
        
        <div class="flex flex-wrap gap-4">
          <a 
            href="#projects" 
            class="px-6 py-3.5 rounded-xl bg-brand-blue hover:bg-brand-blue/90 text-white font-semibold shadow-lg shadow-brand-blue/20 hover:shadow-brand-blue/30 transition-all duration-300 hover:scale-105"
          >
            Explore Projects
          </a>
          <a 
            href="#contact" 
            class="px-6 py-3.5 rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-white font-semibold transition-all duration-300 hover:bg-white/10 hover:scale-105"
          >
            Get in Touch
          </a>
        </div>
      </div>
    </section>

    <!-- Focus Areas Section -->
    <section id="about" class="py-16 md:py-24 border-t border-white/5 scroll-mt-20">
      <div class="mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white mb-4">
          Core Focus Areas
        </h2>
        <p class="text-gray-400 text-sm md:text-base max-w-2xl font-normal">
          How I channel my energy across different domains, color-coded for focus tracking and strategic balance.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Blue Focus -->
        <div class="glass-card p-6 rounded-2xl border border-brand-blue/10 hover:border-brand-blue/30 group">
          <div class="w-10 h-10 rounded-xl bg-brand-blue/10 text-brand-blue border border-brand-blue/20 flex items-center justify-center mb-6 font-bold text-lg">
            💻
          </div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-brand-blue transition-colors">
            Deep Work & Dev
          </h3>
          <p class="text-xs font-semibold text-brand-blue/80 uppercase tracking-wider mb-3">Blue Domain</p>
          <p class="text-gray-400 text-sm leading-relaxed font-normal">
            Software design and product engineering. Building applications (Steward, CADdrive, Mentawise) with cutting-edge architectures.
          </p>
        </div>

        <!-- Yellow Focus -->
        <div class="glass-card p-6 rounded-2xl border border-brand-yellow/10 hover:border-brand-yellow/30 group">
          <div class="w-10 h-10 rounded-xl bg-brand-yellow/10 text-brand-yellow border border-brand-yellow/20 flex items-center justify-center mb-6 font-bold text-lg">
            🎓
          </div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-brand-yellow transition-colors">
            Academic & Partners
          </h3>
          <p class="text-xs font-semibold text-brand-yellow/80 uppercase tracking-wider mb-3">Yellow Domain</p>
          <p class="text-gray-400 text-sm leading-relaxed font-normal">
            Teaching Industrial Informatics, organizing lectures, exams, and coordinating project work with external industrial partners.
          </p>
        </div>

        <!-- Purple Focus -->
        <div class="glass-card p-6 rounded-2xl border border-brand-purple/10 hover:border-brand-purple/30 group">
          <div class="w-10 h-10 rounded-xl bg-brand-purple/10 text-brand-purple border border-brand-purple/20 flex items-center justify-center mb-6 font-bold text-lg">
            🎯
          </div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-brand-purple transition-colors">
            Strategy & Briefings
          </h3>
          <p class="text-xs font-semibold text-brand-purple/80 uppercase tracking-wider mb-3">Purple Domain</p>
          <p class="text-gray-400 text-sm leading-relaxed font-normal">
            Educational curriculum design, research program management, strategic advisory, and administrative briefings.
          </p>
        </div>

        <!-- Green Focus -->
        <div class="glass-card p-6 rounded-2xl border border-brand-green/10 hover:border-brand-green/30 group">
          <div class="w-10 h-10 rounded-xl bg-brand-green/10 text-brand-green border border-brand-green/20 flex items-center justify-center mb-6 font-bold text-lg">
            🏃‍♂️
          </div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-brand-green transition-colors">
            Personal & Sport
          </h3>
          <p class="text-xs font-semibold text-brand-green/80 uppercase tracking-wider mb-3">Green Domain</p>
          <p class="text-gray-400 text-sm leading-relaxed font-normal">
            Regeneration, sport, and personal development. Critical pillars for ensuring sustainable health and technical performance.
          </p>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="py-16 md:py-24 border-t border-white/5 scroll-mt-20">
      <div class="mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white mb-4">
          Software Products
        </h2>
        <p class="text-gray-400 text-sm md:text-base max-w-2xl font-normal">
          Active platforms and tools designed to optimize product styling, engineering, and visual intelligence.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <ProjectCard 
          title="CADdrive"
          tagline="Product Design Platform"
          description="A modern product design platform for schools and universities. Designing awesome products in larger teams is a valuable skill. To overcome existing learning curve barriers, CADdrive offers an easy-to-use, web-based platform with state-of-the-art product design functionalities."
          href="https://caddrive.org"
          tags={["Web-based", "CAD", "Education", "Collaborative", "Product Design"]}
          accentColor="blue"
        />
        
        <ProjectCard 
          title="Mentawise"
          tagline="Knowledge Graph Visualizer"
          description="An innovative knowledge management solution for visual thinkers. If you like mind mapping, knowledge graphs, and graph visualization, Mentawise lets you quickly assemble your own personal knowledge graphs and share them instantly with others."
          href="https://mentawise.com"
          tags={["Knowledge Management", "Graph Database", "Mind Mapping", "SaaS"]}
          accentColor="blue"
        />
      </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="py-16 md:py-24 border-t border-white/5 scroll-mt-20">
      <div class="mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white mb-4">
          Professional Timeline
        </h2>
        <p class="text-gray-400 text-sm md:text-base max-w-2xl font-normal">
          A summary of my academic tenure, software engineering developments, and organizational leadership roles.
        </p>
      </div>

      <Timeline />
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-16 md:py-24 border-t border-white/5 scroll-mt-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Copywriting Left -->
        <div class="lg:col-span-5">
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white mb-6">
            Get In Touch
          </h2>
          <p class="text-gray-400 text-sm md:text-base leading-relaxed mb-8 font-normal">
            Whether you want to discuss educational initiatives, collaborate on software architectures, explore knowledge graphs, or just say hello—feel free to reach out. I am always happy to share experiences!
          </p>

          <!-- Social Shortcuts -->
          <div class="flex items-center space-x-4">
            <!-- Github -->
            <a href="https://github.com/ghackenberg" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-xl glass-card flex items-center justify-center text-gray-400 hover:text-white hover:border-brand-blue/30 transition-all duration-300 hover:scale-110" aria-label="GitHub Profile">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
            </a>
            <!-- LinkedIn -->
            <a href="https://www.linkedin.com/in/georghackenberg/" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-xl glass-card flex items-center justify-center text-gray-400 hover:text-white hover:border-brand-purple/30 transition-all duration-300 hover:scale-110" aria-label="LinkedIn Profile">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
              </svg>
            </a>
            <!-- Twitter / X -->
            <a href="https://twitter.com/georghackenberg" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-xl glass-card flex items-center justify-center text-gray-400 hover:text-white hover:border-brand-yellow/30 transition-all duration-300 hover:scale-110" aria-label="Twitter Profile">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </a>
            <!-- YouTube -->
            <a href="https://youtube.com/@georghackenberg" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-xl glass-card flex items-center justify-center text-gray-400 hover:text-white hover:border-brand-green/30 transition-all duration-300 hover:scale-110" aria-label="YouTube Channel">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.507a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.87.507 9.388.507 9.388.507s7.518 0 9.388-.507a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Contact Card Right -->
        <div class="lg:col-span-7">
          <div class="glass-card p-6 md:p-10 rounded-3xl border border-white/5 relative overflow-hidden">
            <!-- Accent gradient line on top -->
            <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-brand-blue via-brand-purple to-brand-yellow"></div>
            
            <h3 class="text-xl md:text-2xl font-extrabold text-white mb-8 tracking-tight">
              Dr. rer. nat. Georg Hackenberg BSc MSc
            </h3>

            <div class="space-y-6 text-sm md:text-base">
              
              <!-- Role -->
              <div class="flex items-start space-x-4">
                <div class="text-brand-yellow shrink-0 mt-0.5">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-white font-semibold">Professor for Industrial Informatics</p>
                  <p class="text-gray-400 text-sm">Area Manager for Information Technology</p>
                </div>
              </div>

              <!-- Institution -->
              <div class="flex items-start space-x-4">
                <div class="text-brand-purple shrink-0 mt-0.5">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-white font-semibold">School of Engineering</p>
                  <p class="text-gray-400 text-sm">University of Applied Sciences Upper Austria</p>
                </div>
              </div>

              <!-- Address -->
              <div class="flex items-start space-x-4">
                <div class="text-brand-green shrink-0 mt-0.5">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-white font-semibold">Stelzhamerstrasse 23</p>
                  <p class="text-gray-400 text-sm">4600 Wels, Austria</p>
                </div>
              </div>

              <!-- Email Action -->
              <div class="flex items-start space-x-4 pt-4 border-t border-white/5">
                <div class="text-brand-blue shrink-0 mt-1">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div class="flex-grow flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                  <div>
                    <p class="text-gray-500 text-xs font-semibold uppercase tracking-wider">Email Address</p>
                    <p id="email-text" class="text-white font-mono font-medium mt-0.5 select-all">georg.hackenberg@fh-wels.at</p>
                  </div>
                  
                  <button 
                    id="copy-email-btn"
                    class="px-4 py-2 text-xs font-semibold rounded-lg bg-white/5 hover:bg-white/10 text-gray-300 hover:text-white border border-white/10 hover:border-white/20 transition-all duration-200 self-start sm:self-auto flex items-center space-x-2"
                  >
                    <svg id="copy-icon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
                    </svg>
                    <span id="copy-btn-text">Copy Email</span>
                  </button>
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="w-full glass-panel border-t border-white/5 py-8 text-center text-xs text-gray-500 relative z-10">
    <div class="max-w-6xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p>&copy; {new Date().getFullYear()} Dr. Georg Hackenberg. All rights reserved.</p>
      <div class="flex space-x-6">
        <a href="#home" class="hover:text-gray-300 transition-colors">Back to top</a>
      </div>
    </div>
  </footer>
</Layout>

<script>
  // Copy to Clipboard logic for contact button
  const copyBtn = document.getElementById('copy-email-btn');
  const emailText = document.getElementById('email-text');
  const copyBtnText = document.getElementById('copy-btn-text');
  const copyIcon = document.getElementById('copy-icon');

  if (copyBtn && emailText && copyBtnText && copyIcon) {
    copyBtn.addEventListener('click', () => {
      const email = emailText.textContent?.trim() || 'georg.hackenberg@fh-wels.at';
      
      navigator.clipboard.writeText(email).then(() => {
        // Visual feedback
        copyBtnText.textContent = 'Copied!';
        copyBtn.classList.remove('bg-white/5', 'text-gray-300', 'border-white/10');
        copyBtn.classList.add('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
        
        // Reset after 2.5 seconds
        setTimeout(() => {
          copyBtnText.textContent = 'Copy Email';
          copyBtn.classList.remove('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
          copyBtn.classList.add('bg-white/5', 'text-gray-300', 'border-white/10');
        }, 2500);
      }).catch(err => {
        console.error('Failed to copy text: ', err);
      });
    });
  }
</script>
